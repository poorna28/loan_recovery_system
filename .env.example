# Environment Configuration
# Copy this file to .env and fill in with your actual values
# NEVER commit .env to version control

# ============= DATABASE CONFIGURATION =============
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_secure_password_here
DB_NAME=loan_recovery_system

# ============= APPLICATION =============
NODE_ENV=development
PORT=5000

# ============= AUTHENTICATION =============
# Generate a strong secret using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_very_secure_jwt_secret_at_least_32_characters_long
JWT_EXPIRY=1h

# ============= CORS =============
# Frontend URL for CORS configuration
CORS_ORIGIN=http://localhost:3000

# ============= RATE LIMITING =============
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# ============= LOGGING =============
# Set to true to enable debug logging
DEBUG=false

# ============= SECURITY =============
# Set to true for production deployments (enforces HTTPS)
SECURE_COOKIES=false
